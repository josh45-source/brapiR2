# Normalize line endings for cross-platform collaboration
* text=auto

# R source files — always LF in the repo
*.R     text eol=lf
*.Rmd   text eol=lf
*.Rd    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf

# Binary assets — never diff or convert
*.png   binary
*.jpg   binary
*.pdf   binary
*.rds   binary
*.RData binary
